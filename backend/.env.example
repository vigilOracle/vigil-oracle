# Helius RPC URL — get a free key at https://helius.dev
# whale-watch derives the Enhanced Tx API key from this URL.
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Port the server listens on (Railway overrides this in production).
PORT=3001

# Allowed CORS origin. Use * during dev so the frontend can fetch from anywhere.
FRONTEND_ORIGIN=*
